# 1. Pauli Operators

- Fundamental blocks in performing single- and multi-qubit operations.
- Pauli operators are Hermitian (equal to its conjugate transpose) and unitary (conjugate transpose is equal to its inverse)
# Setup: Import necessary libraries
from qiskit.quantum_info import Pauli, ScalarOp
import numpy as np
from qiskit import QuantumCircuit

print("Libraries imported successfully.")
#### Initialization


#1. String Representation
p = Pauli('YZXI')

#2. Boolean Representation
z = np.array([False,False,True,True])  
x = np.array([False,True,False,True])  
             #I     X    Z     Y
pauli_array_rep = Pauli((z, x))

#3. Quantum Circuit Representation
qc = QuantumCircuit(4)
qc.id(0)
qc.x(1)
qc.z(2)
qc.y(3)
# Note: pauli op can only be extracted from quantum circuits that only contain pauli gates
pauli_quantum_circuit = Pauli(qc)

print(p, pauli_array_rep, pauli_quantum_circuit)
#4. Scalar Operations

# ScalarOp - scalar multiple of the id op, can be composed with a pauli op to apply a global phase.
# Pauli can only be multiplied by 1, -1, 1j, -1j
scalar_op = ScalarOp(dims=(2,2,2,2), coeff=-1j)
pauli_scalarop = Pauli('YZXI')
p = scalar_op.compose(pauli_scalarop)
print(p)
#### Representation
#1. Matrix representation
p = Pauli('-iYZY')
p_matrix = p.to_matrix()
print(p_matrix)

#2. Label representation
print(f"String format:{str(p)}")
print(f"Label format:{p.to_label()}")

# Note: An error occurs when the label function is applied to the matrix variable.
#### Attributes
# Access Pauli operator attributes
print(f"Dimension: {p.dim}")  # Dimension of the operator matrix
print(f"Classical bits: {p.num_clbits}, Qubits: {p.num_qubits}")  # Number of qubits
print(f"X: {p.x}, Z: {p.z}, Phase: {p.phase}")  # Components and phase

# Number of classical bits (always 0 for pauli op)
# Phase of op (0, 1, 2, 3 representing +1, -i, -1, i)
#### Methods
# 1. adjoint (conjugate transpose)
# For pauli op, adjoint is the same but phase may change
print(f"Adjoint of {p}: {p.adjoint()}")

# 2. anticommutes (AB = -BA)
# Number of qubits should match
p1 = Pauli('X')      
p2 = Pauli('iZ')     
print(f"{p1} anticommutes with {p2} is {p1.anticommutes(p2)}")

# 5. conjugate (complex conjugate)
# For real pauli op (no imaginary phase), conjugate is the same
print(f"Conjugate of {p} is {p.conjugate()}")

# 4. transpose
print(f"Transpose of {p} is {p.transpose()}")

# 5. inverse
print(f"Inverse of {p} is {p.inverse()}")

# 6. compose (left matrix multiplication. operator composition)
# front=True changes it to dot(), inplace=True updates original variable)
print(f"{p1} compose with {p2} is {p1.compose(p2)}")

# 7. dot (right matrix multiplication. the same as manually multiplying matrices)
print(f"Dot product of {p1} and {p2} is {p1.dot(p2)}")

# 8. delete
qubit_index = 0
delete_0 = p.delete(qubit_index)
print(f"{p} after deleting qubit {qubit_index} is {delete_0}")

# 9. insert
qubit_index = 0
insert_0 = delete_0.insert(qubit_index, Pauli('Y'))
print(f"{delete_0} after inserting X at qubit {qubit_index} is {insert_0}")

# 10. instruction
# can be used in quantum circuits
p.to_instruction()

# 11. apply_layout
# either permutes of expands the pauli op based on the layout provided
print(f"{p} after applying layout [2,0,1] is {p.apply_layout([2,0,1])}")
print(f"{p} after applying layout with 5 qubits is {p.apply_layout(None, num_qubits=5)}")

# 12. copy
# make a deep copy of pauli op. new copy is independent of original op.
print(f"Copy of {p} is {p.copy()}")

# 13. equiv
print(f"{p} is equivalent to {p.copy()} is {p.equiv(p.copy())}")
# 14. evolve
# Performs Heisenberg (default) or frame='h' 
# Performs Schrödinger of the Pauli by a Clifford or frame='s'
# Heisenberg picture evolves the Pauli as P′= C†.P.C.
# Schrödinger picture evolves the Pauli as P′ = C.P.C†.
print(f"{p1} evolved by {p2} in Heisenberg picture is {p1.evolve(p2)}")
print(f"{p1} evolved by {p2} in Schrödinger picture is {p1.evolve(p2, frame='s')}")

# 15. tensor (a^b = a⊗b)
print(f"Tensor product of {p1} and {p2} is {p1.tensor(p2)}")

# 16. expand (reverse-order tensor product. a.expand(b) = b⊗a)
print(f"{p1} expanded with {p2} is {p1.expand(p2)}")

# 17. input_dims (returns tuple of input dimension)
print(f"Input dimensions of {p} is {p.input_dims()}")

# 18. output_dims (returns tuple of output dimension)
print(f"Output dimensions of {p} is {p.output_dims()}")

# 19. power (returns composition of op with itself n times)
print(f"{p} to the power of 2 is {p.power(2)}")
#  An error occurs if the input and output dimensions of the operator are not equal, or the power is not a positive integer.

